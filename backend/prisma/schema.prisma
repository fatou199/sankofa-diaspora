// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  lastName          String
  firstName         String
  email             String   @unique
  password          String
  birthDate         DateTime?
  diasporaCountry   String
  originDetails     String?  // Free text for multiple origins or precise city
            
  // Relations            
  origins           Country[] @relation("UserOrigins")
  itineraries       Itinerary[] 
  stays             Stay[]
  reviewsHotel      ReviewHotel[]
  reviewsRestaurant ReviewRestaurant[]
  reviewsActivity   ReviewActivity[]
  favoritesHotel    FavoriteHotel[]
  favoritesRestaurant FavoriteRestaurant[]
  favoritesActivity  FavoriteActivity[]
            
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("users")
}
            
model Country {            
  id                 Int      @id @default(autoincrement())
  name               String
  image              String? 
  imageMap           String?
  description        String   @db.Text
  currency           String
  capital            String?
  isoCode            String?
  officialLanguages  String?
  population         String?
  bestPeriod         String?
  
  // Visa requirements for passports: 
  visaRequiredFR     Boolean  @default(false)

  // Relations
  users              User[]   @relation("UserOrigins")
  cities             City[]
  itineraries        Itinerary[]
            
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("countries")
}

model City {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String   @db.Text
  latitude           Float
  longitude          Float
  countryId          Int    

  // Relations
  country            Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  hotels             Hotel[]
  restaurants        Restaurant[]
  activities         Activity[]
  itineraryDetails   ItineraryDetail[]
  itineraries        Itinerary[] @relation("ItineraryCities")
            
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("cities")
}

model Hotel {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String   @db.Text
  pricePerNight      Float
  comfortLevel       ComfortLevel 
  image              String?
  telephone          String?
  website            String?
  neighborhood       String?
  terrainLogic       String?  @db.Text
  status             String?  @default("VERIFIÉ")
  latitude           Float
  longitude          Float
  cityId             Int

  // Relations
  city               City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  reviews            ReviewHotel[]
  favorites          FavoriteHotel[]
            
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("hotels")
}

model Restaurant {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String   @db.Text
  cuisineType        CuisineType          
  establishmentType  EstablishmentType    
  dietTypes          DietType[]           
  address            String
  averagePrice       Float
  openingHours       String
  phone              String?
  image              String?
  website            String?
  neighborhood       String?
  terrainLogic       String?  @db.Text
  isHalal            Boolean  @default(false)
  isLocal            Boolean  @default(false)
  status             String?  @default("VERIFIÉ")
  latitude           Float
  longitude          Float
  cityId             Int

  // Relations
  city               City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  reviews            ReviewRestaurant[]
  favorites          FavoriteRestaurant[]
  itineraryRestaurants ItineraryRestaurant[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("restaurants")
}

model Activity {
  id                 Int      @id @default(autoincrement())
  name               String
  description        String   @db.Text
  price              Float
  openingHours       String
  category           ActivityCategory
  address            String
  image              String?
  telephone          String?
  website            String?
  neighborhood       String?
  terrainLogic       String?  @db.Text
  duration           String?
  status             String?  @default("VERIFIÉ")
  latitude           Float
  longitude          Float
  cityId             Int

  // Relations
  city               City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  reviews            ReviewActivity[]
  favorites          FavoriteActivity[]
  itineraryActivities ItineraryActivity[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("activities")
}

model Itinerary {
  id                 Int      @id @default(autoincrement())
  startDate          DateTime
  endDate            DateTime
  budget             Float
  adults             Int                @default(1)
  children           Int                @default(0)
  interests          ActivityCategory[]
  userId             Int
  countryId          Int?                // Pays de destination
  cityIds            Int[]               @default([]) // Liste des IDs de villes
  cities             City[]              @relation("ItineraryCities")

  // Relations
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country            Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  details            ItineraryDetail[]
  stays              Stay[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("itineraries")
}

model ItineraryDetail {
  id                 Int      @id @default(autoincrement())
  day                Int  
  notes              String   @db.Text
  itineraryId        Int
  cityId             Int?     // A trip can pass through multiple cities

  // Relations
  itinerary          Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  city               City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  activities         ItineraryActivity[]
  restaurants        ItineraryRestaurant[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("itinerary_details")
}

model ItineraryActivity {
  id                 Int      @id @default(autoincrement())
  itineraryDetailId  Int 
  activityId         Int

  // Relations
  itineraryDetail    ItineraryDetail @relation(fields: [itineraryDetailId], references: [id], onDelete: Cascade)
  activity           Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([itineraryDetailId, activityId])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("itinerary_activities")
}

model ItineraryRestaurant {
  id                 Int      @id @default(autoincrement())
  itineraryDetailId  Int
  restaurantId       Int

  // Relations
  itineraryDetail    ItineraryDetail @relation(fields: [itineraryDetailId], references: [id], onDelete: Cascade)
  restaurant         Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([itineraryDetailId, restaurantId])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("itinerary_restaurants")
}

model Stay {
  id                 Int      @id @default(autoincrement())
  userId             Int
  itineraryId        Int
  actualStartDate    DateTime
  actualEndDate      DateTime
  spentBudget        Float

  // Relations
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary          Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("stays")
}

model ReviewHotel {
  id                Int      @id @default(autoincrement())
  userId            Int
  hotelId           Int
  rating            Int      // 1-5
  comment           String   @db.Text
  reviewDate        DateTime @default(now())
              
  // Relations            
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
              
  @@unique([userId, hotelId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("hotel_reviews")
}

model ReviewRestaurant {
  id                Int      @id @default(autoincrement())
  userId            Int
  restaurantId      Int
  rating            Int      // 1-5
  comment           String   @db.Text
  reviewDate        DateTime @default(now())
  
  // Relations
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  @@unique([userId, restaurantId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("restaurant_reviews")
}

model ReviewActivity {
  id                Int      @id @default(autoincrement())
  userId            Int
  activityId        Int
  rating            Int      // 1-5
  comment           String   @db.Text
  reviewDate        DateTime @default(now())
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
              
  @@unique([userId, activityId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("activity_reviews")
}
            
            
model FavoriteHotel {            
  id                Int      @id @default(autoincrement())
  userId            Int
  hotelId           Int
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  
  @@unique([userId, hotelId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("favorite_hotels")
}

model FavoriteRestaurant {
  id                Int      @id @default(autoincrement())
  userId            Int
  restaurantId      Int
  
  // Relations
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  @@unique([userId, restaurantId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("favorite_restaurants")
}

model FavoriteActivity {
  id                Int      @id @default(autoincrement())
  userId            Int
  activityId        Int
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  @@unique([userId, activityId])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("favorite_activities")
}

// Enums
enum ComfortLevel {
  BASIC
  COMFORTABLE
  LUXURY
}

enum CuisineType {
  AFRICAN
  AMERICAN
  ASIAN
  EUROPEAN
  INDIAN
  OTHER
}

enum EstablishmentType {
  RESTAURANT        // Restaurant classique
  BRUNCH            // Brunch / petit-déjeuner
  PATISSERIE        // Pâtisserie, salon de thé
  CAFE              // Coffee shop
  STREET_FOOD       // Maquis, garba, choukouya
  BAR               // Bar, lounge
  FAST_FOOD         // Fast food
  GASTRONOMIC       // Haute cuisine
  BUFFET            // Buffet à volonté
  FOOD_TRUCK        // Food truck
  ROOFTOP           // Rooftop
}

enum DietType {
  NONE
  VEGETARIAN
  VEGAN
  HALAL
  KOSHER
  PESCATARIAN       // Poisson uniquement
  GLUTEN_FREE
  ORGANIC
}

enum ActivityCategory {
  SPORT
  CULTURE
  GASTRONOMY
  NATURE
  LEISURE
  HISTORY
  ART
  ADVENTURE
  RELAXATION
  BEACH
  PHOTOGRAPHY
  SHOPPING
  OTHER
}
