// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               Int     @id @default(autoincrement())
  nom                              String
  prenom                           String
  email                            String  @unique
  password                         String
  date_naiss                       DateTime?
  diaspora_country                 String
  origin_country_id                Int
            
  // Relations            
  origin_country                   Pays @relation(fields: [origin_country_id], references: [id], onDelete: Cascade)
  itineraires                      Itineraire[] 
  sejours                          Sejours[]
  avis_hotels                      AvisHotel[]
  avis_restaurants                 AvisRestaurant[]
  avis_activites                   AvisActivite[]
  favoris_hotels                   FavorisHotel[]
  favoris_restaurants              FavorisRestaurant[]
  favoris_activites                FavorisActivite[]
            
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}            
            
model Pays {            
  id                               Int     @id @default(autoincrement())
  image                            String? 
  nom                              String
  description                      String @db.Text
  monnaie                          String

  // Relations
  users                            User[]
  villes                           Villes[]
            
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Villes {
  id                               Int     @id @default(autoincrement())
  nom                              String
  description                      String @db.Text
  latitude                         Float
  longitude                        Float
  pays_id                          Int    

  // Relations
  pays                             Pays @relation(fields: [pays_id], references: [id], onDelete: Cascade)
  hotels                           Hotels[]
  restaurants                      Restaurant[]
  activites                        Activite[]
  itineraires                      Itineraire[]
            
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Hotels {
  id                               Int     @id @default(autoincrement())
  nom                              String
  description                      String @db.Text
  prix_nuit                        Float
  niveau_confort                   NiveauConfort 
  latitude                         Float
  longitude                        Float
  ville_id                         Int

  // Relations
  ville                            Villes @relation(fields: [ville_id], references: [id], onDelete: Cascade)
  avis_hotels                      AvisHotel[]
  favoris_hotels                   FavorisHotel[]
            
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Restaurant {
  id                               Int      @id @default(autoincrement())
  nom                              String
  description                      String   @db.Text
  cuisine                          TypeCuisine  
  adresse                          String
  prix_moyen                       Float
  horaires                         String
  telephone                        String?
  latitude                         Float
  longitude                        Float
  ville_id                         Int

  // Relations
  ville                            Villes @relation(fields: [ville_id], references: [id], onDelete: Cascade)
  avis_restaurants                 AvisRestaurant[]
  favoris_restaurants              FavorisRestaurant[]
  itineraires_restaurants          ItineraireRestaurant[]

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Activite {
  id                               Int    @id @default(autoincrement())
  nom                              String
  description                      String @db.Text
  prix                             Float
  horaire                          String
  categorie                        CategorieActivite
  adresse                          String
  latitude                         Float
  longitude                        Float
  ville_id                         Int

  // Relations
  ville                            Villes @relation(fields: [ville_id], references: [id], onDelete: Cascade)
  avis_activites                   AvisActivite[]
  favoris_activites                FavorisActivite[]
  itineraires_activites            ItineraireActivite[]

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Itineraire {
  id                               Int      @id @default(autoincrement())
  date_debut                       DateTime
  date_fin                         DateTime
  budget                           Float
  preferences                      String   @db.Text
  user_id                          Int
  ville_id                         Int

  // Relations
  user                             User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ville                            Villes @relation(fields: [ville_id], references: [id], onDelete: Cascade)
  details                          ItineraireDetail[]
  sejours                          Sejours[]

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}


model ItineraireDetail {
  id                               Int      @id @default(autoincrement())
  jour                             Int  
  notes                            String   @db.Text
  itineraire_id                    Int

  // Relations
  itineraire                       Itineraire @relation(fields: [itineraire_id], references: [id], onDelete: Cascade)
  activites                        ItineraireActivite[]
  restaurants                      ItineraireRestaurant[]

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}


model ItineraireActivite {
  id                               Int      @id @default(autoincrement())
  itineraire_detail_id             Int 
  activite_id                      Int

  // Relations
  itineraire_detail                ItineraireDetail @relation(fields: [itineraire_detail_id], references: [id], onDelete: Cascade)
  activite                         Activite @relation(fields: [activite_id], references: [id], onDelete: Cascade)

  @@unique([itineraire_detail_id, activite_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt


}

model ItineraireRestaurant {
  id                               Int      @id @default(autoincrement())
  itineraire_detail_id             Int
  restaurant_id                    Int

  // Relations
  itineraire_detail                ItineraireDetail @relation(fields: [itineraire_detail_id], references: [id], onDelete: Cascade)
  restaurant                       Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@unique([itineraire_detail_id, restaurant_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model Sejours {
  id                               Int      @id @default(autoincrement())
  user_id                          Int
  itineraire_id                    Int
  date_debut_reel                  DateTime
  date_fin_reel                    DateTime
  budget_depense                   Float

  // Relations
  user                             User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  itineraire                       Itineraire @relation(fields: [itineraire_id], references: [id], onDelete: Cascade)

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

// Tables d'avis séparées
model AvisHotel {
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  hotel_id                         Int
  rating                           Int     // 1-5
  commentaire                      String  @db.Text
  date_avis                        DateTime @default(now())
              
  // Relations            
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  hotel                            Hotels  @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
              
  @@unique([user_id, hotel_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model AvisRestaurant {
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  restaurant_id                    Int
  rating                           Int     // 1-5
  commentaire                      String  @db.Text
  date_avis                        DateTime @default(now())
  
  // Relations
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurant                       Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id, restaurant_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model AvisActivite {
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  activite_id                      Int
  rating                           Int     // 1-5
  commentaire                      String  @db.Text
  date_avis                        DateTime @default(now())
  
  // Relations
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  activite                         Activite @relation(fields: [activite_id], references: [id], onDelete: Cascade)
              
  @@unique([user_id, activite_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}            
            
// Tables de favoris séparées
model FavorisHotel {            
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  hotel_id                         Int
  
  // Relations
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  hotel                            Hotels  @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id, hotel_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model FavorisRestaurant {
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  restaurant_id                    Int
  
  // Relations
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurant                       Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id, restaurant_id])
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

model FavorisActivite {
  id                               Int     @id @default(autoincrement())
  user_id                          Int
  activite_id                      Int
  
  // Relations
  user                             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  activite                         Activite @relation(fields: [activite_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id, activite_id])
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}



// Enums
enum NiveauConfort {
  BASIQUE
  CONFORTABLE
  LUXE
}

enum TypeCuisine {
  FRANCAISE
  ITALIENNE
  ASIATIQUE
  AFRICAINE
  INDIENNE
  VEGETARIENNE
  AUTRE
}

enum CategorieActivite {
  SPORT
  CULTURE
  GASTRONOMIE
  NATURE
  LOISIRS
  HISTOIRE
  ART
  AVENTURE
  RELAXATION
  AUTRE
}